# ─────────────────────────────────────────────────────────────────────────────
# RegulaOne Frontend — Environment Variables
# Copy this file to .env for local dev, or set in your CI/CD pipeline.
# All VITE_ variables are bundled into the browser build by Vite.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the Spring Boot backend (shared by every app in the ecosystem).
# Local dev:  http://localhost:8080
# Production: https://api.regulaone.eu
VITE_API_URL=http://localhost:8080

# Short identifier for THIS app.
# Used in the SSO state parameter so the backend knows which app initiated
# the login and where to send the user after authentication completes.
#
#   regulaone    → Main RegulaOne dashboard  (port 3000 in dev)
#   ksefflow     → KSeF e-invoicing          (port 3001 in dev)
#   workpulse    → Time tracking             (port 3002 in dev)
#   safework     → HR/BHP compliance         (port 3003 in dev)
#   safevoice    → Whistleblower             (port 3004 in dev)
#   wastesync    → BDO waste reporting       (port 3005 in dev)
#   privacypilot → GDPR/RODO                 (port 3006 in dev)
VITE_APP_ID=regulaone

# Full base URL of THIS app (no trailing slash).
# Used to build the /auth/sso-callback URL that is passed as redirect_uri
# to /api/sso/login so the user lands back in this app after logging in.
# Local dev:  http://localhost:3000  (change port per module app)
# Production: https://app.regulaone.eu  (or module subdomain)
VITE_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Per-app values — copy the right block into each module app's .env
# ─────────────────────────────────────────────────────────────────────────────
#
# LOCAL DEV (all share VITE_API_URL=http://localhost:8080)
#   regulaone    VITE_APP_ID=regulaone    VITE_APP_URL=http://localhost:3000
#   ksefflow     VITE_APP_ID=ksefflow    VITE_APP_URL=http://localhost:3001
#   workpulse    VITE_APP_ID=workpulse   VITE_APP_URL=http://localhost:3002
#   safework     VITE_APP_ID=safework    VITE_APP_URL=http://localhost:3003
#   safevoice    VITE_APP_ID=safevoice   VITE_APP_URL=http://localhost:3004
#   wastesync    VITE_APP_ID=wastesync   VITE_APP_URL=http://localhost:3005
#   privacypilot VITE_APP_ID=privacypilot VITE_APP_URL=http://localhost:3006
#
# PRODUCTION (all share VITE_API_URL=https://api.regulaone.eu)
#   regulaone    VITE_APP_ID=regulaone    VITE_APP_URL=https://app.regulaone.eu
#   ksefflow     VITE_APP_ID=ksefflow    VITE_APP_URL=https://ksefflow.regulaone.eu
#   workpulse    VITE_APP_ID=workpulse   VITE_APP_URL=https://workpulse.regulaone.eu
#   safework     VITE_APP_ID=safework    VITE_APP_URL=https://safework.regulaone.eu
#   safevoice    VITE_APP_ID=safevoice   VITE_APP_URL=https://safevoice.regulaone.eu
#   wastesync    VITE_APP_ID=wastesync   VITE_APP_URL=https://wastesync.regulaone.eu
#   privacypilot VITE_APP_ID=privacypilot VITE_APP_URL=https://privacypilot.regulaone.eu
