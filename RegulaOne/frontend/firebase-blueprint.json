{
  "entities": {
    "tenant": {
      "title": "Tenant",
      "description": "Enterprise company using the platform",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "taxId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "subscriptionTier": { "type": "string", "enum": ["Basic", "Pro", "Enterprise"] },
        "enabledModules": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status"]
    },
    "userProfile": {
      "title": "User Profile",
      "description": "User account information linked to a tenant",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["SUPER_ADMIN", "ADMIN", "USER"] },
        "tenantId": { "type": "string" },
        "displayName": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended"] }
      },
      "required": ["email", "role", "status"]
    },
    "auditLog": {
      "title": "Audit Log",
      "description": "Immutable record of system activity",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "tenantId": { "type": "string" },
        "action": { "type": "string" },
        "entity": { "type": "string" },
        "details": { "type": "string" },
        "ip": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "invoice": {
      "title": "KSeF Invoice",
      "description": "Electronic invoice in FA(3) format",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "sent", "accepted", "rejected"] },
        "xmlPath": { "type": "string" },
        "upoPath": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "issueDate": { "type": "string", "format": "date" }
      }
    }
  },
  "firestore": {
    "/tenants/{tenantId}": {
      "schema": "tenant",
      "description": "Root collection for isolated company data"
    },
    "/users/{userId}": {
      "schema": "userProfile",
      "description": "Global user profiles with tenant isolation via tenantId"
    },
    "/tenants/{tenantId}/auditLogs/{logId}": {
      "schema": "auditLog",
      "description": "Tenant-specific audit trails"
    },
    "/tenants/{tenantId}/invoices/{invoiceId}": {
      "schema": "invoice",
      "description": "KSeF e-invoices"
    }
  }
}
