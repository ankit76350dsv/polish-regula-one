{
  "info": {
    "name": "SafeVoice",
    "description": "SafeVoice (whistleblowing) API \u2014 one folder per controller. Base port 9003. TWO auth models:\n\u2022 PUBLIC /api/safevoice/** \u2014 anonymous reporter, NO login; identified by the case accessKey/PIN returned at submission.\n\u2022 INTERNAL /api/v1/internal/** \u2014 staff, requires the RegulaOne idToken cookie (log in via RegulaOne SSO first; the Bearer {{token}} header is a fallback).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:9003"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
