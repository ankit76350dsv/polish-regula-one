                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "safevoice",
                "reports"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"TENANT_ID_HERE\",\n  \"category\": \"fraud\",\n  \"incidentDate\": \"2026-05-01\",\n  \"area\": \"Finance department\",\n  \"facts\": \"Describe what happened here (plaintext if not client-side encrypted).\",\n  \"channel\": \"web\",\n  \"requestMeeting\": false,\n  \"attachments\": [],\n  \"encryptedContent\": null\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
