# Server
PORT=8082
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/safework

# JWT
JWT_SECRET=your-very-secure-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3002

# RegulaOne integration — user/identity API base URL
REGULA_ONE_API_URL=http://localhost:8080

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# AWS S3 — Compliance document storage (must be in EU region for GDPR)
AWS_REGION=eu-central-1
AWS_S3_BUCKET=your-safework-documents-bucket
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
