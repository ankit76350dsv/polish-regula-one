# The central RegulaOne backend that owns auth (/api/auth/me, /api/sso/logout).
VITE_API_URL=http://localhost:8080

# This WasteSync backend (companies, waste entries, reports, dashboard, audit).
VITE_WASTESYNC_API_URL=http://localhost:8083

# This WasteSync frontend's own address (used to build the SSO callback URL).
VITE_APP_URL=http://localhost:3003

# The central RegulaOne login page the user is redirected to when not signed in.
VITE_CENTRAL_LOGIN_URL=http://localhost:3000/login
