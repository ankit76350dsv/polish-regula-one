# ─── Server ──────────────────────────────────────────────────────────────────
# The port this WasteSync backend listens on. SafeWork uses 8082, so we use 8083
# to avoid a clash when both run at the same time on one machine.
PORT=8083
NODE_ENV=development

# ─── MongoDB ─────────────────────────────────────────────────────────────────
# Connection string for the WasteSync database.
MONGODB_URI=mongodb://localhost:27017/wastesync

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call this API.
# The WasteSync React app runs on port 3003 (see frontend/vite.config.js).
CORS_ORIGIN=http://localhost:3003

# ─── RegulaOne SSO integration ───────────────────────────────────────────────
# RegulaOne is the central login service. WasteSync asks it "who is this user?"
# by calling GET /api/auth/me, which returns the authoritative tenantId.
REGULAONE_API_URL=http://localhost:8080

# ─── AWS Cognito (shared with RegulaOne SSO) ─────────────────────────────────
# The login token is a Cognito JWT set by RegulaOne in a shared HttpOnly cookie.
# We only VERIFY it here — we never issue tokens ourselves.
AWS_COGNITO_USER_POOL_ID=your-user-pool-id
# Comma-separated client ids (web + mobile app clients share one user pool).
AWS_COGNITO_CLIENT_ID=your-web-client-id,your-mobile-client-id
AWS_COGNITO_TOKEN_USE=id

# ─── Rate limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── AWS S3 — report storage (MUST be an EEA region for GDPR/RODO) ───────────
# Generated XML + PDF reports are stored in a PRIVATE, versioned bucket.
# Clients only ever receive short-lived presigned URLs.
AWS_REGION=eu-central-1
AWS_S3_BUCKET=your-wastesync-reports-bucket
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
