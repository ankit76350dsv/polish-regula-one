# Server
PORT=8085
NODE_ENV=development

# MongoDB
# WorkPulse shares the SAME MongoDB database as the rest of the RegulaOne
# platform. It needs read access to the shared `users` collection (identity)
# and to SafeWork's `safework_employees` collection (clock-in eligibility),
# and it writes its own `workplus_*` collections into the same database.
MONGODB_URI=mongodb://localhost:27017/safework

# CORS — the WorkPulse frontend runs on :3005 in development
CORS_ORIGIN=http://localhost:3005

# RegulaOne integration — central identity / SSO API base URL (Java, :8080)
REGULAONE_API_URL=http://localhost:8080

# AWS Cognito — token verification (shared user pool with the rest of the platform)
# A comma-separated list of app-client ids is supported (web + mobile clients).
AWS_COGNITO_USER_POOL_ID=your-user-pool-id
AWS_COGNITO_CLIENT_ID=your-web-client-id,your-mobile-client-id
AWS_COGNITO_TOKEN_USE=id

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Scheduled jobs (cron) — set to "false" to disable the WorkPulse cron jobs
# (useful when running multiple instances so jobs only run on one node).
ENABLE_CRON_JOBS=true
