# PrivacyPilot frontend — environment variables.
#
# Copy this file to ".env" (or ".env.local") to override the defaults. Every
# variable is OPTIONAL for local development: the code falls back to the local
# port map below if a value is not set. All names must start with VITE_ so Vite
# exposes them to the browser bundle.
#
# Authentication is RegulaOne single sign-on (SSO): staff sign in once on the
# central RegulaOne login, which sets a shared-domain httpOnly cookie. PrivacyPilot
# only calls the RegulaOne auth endpoints below — its own feature data is local.

# The central RegulaOne backend (handles /api/auth/me, /api/sso/refresh, /api/sso/logout).
VITE_REGULAONE_API_URL=http://localhost:8080

# PrivacyPilot's OWN backend — the ROPA / GDPR feature API (/api/privacypilot/**).
# It runs on a separate port from the RegulaOne auth backend. Local dev default: 9004.
VITE_PRIVACYPILOT_API_URL=http://localhost:9004

# The central RegulaOne login page the user is redirected to when not signed in.
VITE_CENTRAL_LOGIN_URL=http://localhost:3000/login

# This PrivacyPilot frontend's own public URL. Used to build the SSO callback URL
# (<VITE_APP_URL>/auth/sso-callback) the central login returns the browser to.
VITE_APP_URL=http://localhost:3006
