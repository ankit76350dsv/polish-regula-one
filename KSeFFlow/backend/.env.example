# KSeFFlow Backend — Environment Variables Template
# Copy this file to .env and fill in the values.
# NEVER commit .env to git — it contains secrets.

# ── Spring Profile ────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/ksefflow_dev

# ── Certificate Encryption ────────────────────────────────────────────────────
# 32-byte (256-bit) hex key for AES-256-GCM encryption of .pfx files and passwords.
# Generate with: openssl rand -hex 32
# Example (DO NOT USE THIS IN REAL PROJECTS):
KSEF_CERT_ENCRYPTION_KEY=replace_with_output_of__openssl_rand_-hex_32

# Local directory where encrypted certificate files are stored (dev only).
# In production this becomes an S3 key prefix.
KSEF_CERT_STORAGE_PATH=./ksef-certs
